# LaSalle Wiki Tutor — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ── Project ────────────────────────────────────────────────
ENVIRONMENT=local
ASSISTANT_NAME="LaSalle Wiki Tutor"
TERMINAL_LOGS_ENABLED=False
LOG_LEVEL=INFO

# ── OpenAI ─────────────────────────────────────────────────
# Required: agent uses OpenAI Responses API via Agno.
OPENAI_API_KEY=sk-your-key-here

# ── Access gate ────────────────────────────────────────────
# Single shared secret for the demo deployment. Distribute by hand to the
# evaluators. If unset (or empty), the gate is OPEN — fine for local dev,
# never deploy that way. Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WIKI_TUTOR_ACCESS_TOKEN=

# ── MongoDB (local / Docker) ───────────────────────────────
# Used when ENVIRONMENT=local. Connection string is read by utils.mongo_connection.
# The local docker `mongo:6.0` container runs without auth — no user/pass.
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=lasalle_catalog_assistant

# ── MongoDB Atlas (production) ─────────────────────────────
# Used when ENVIRONMENT=dev. Optional for local development.
MONGO_CLUSTER=
CLUSTER_APP_NAME=
MONGO_RW_USERNAME=
MONGO_RW_PASSWORD=
