# LaSalle Wiki Tutor — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ── Project ────────────────────────────────────────────────
# ENVIRONMENT=local enables /docs, /redoc, /openapi.json and opens CORS to
# the Vite dev server on :5173. Anything else (prod, dev) hides the auto-docs
# routes and locks CORS + TrustedHost to PUBLIC_HOST below.
ENVIRONMENT=local
# Public hostname this app is served from in non-local environments. Drives
# CORS allow-origin and TrustedHostMiddleware allow-list.
PUBLIC_HOST=lasalle.generateeve.com
ASSISTANT_NAME="LaSalle Wiki Tutor"
TERMINAL_LOGS_ENABLED=False
LOG_LEVEL=INFO

# ── OpenAI ─────────────────────────────────────────────────
# Required: agent uses OpenAI Responses API via Agno.
OPENAI_API_KEY=sk-your-key-here

# ── Access gate ────────────────────────────────────────────
# Single shared secret for the demo deployment. Distribute by hand to the
# evaluators. If unset (or empty), the gate is OPEN — fine for local dev,
# never deploy that way. Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WIKI_TUTOR_ACCESS_TOKEN=

# ── Admin gate (loopback + optional token) ─────────────────
# Gates /api/admin/* (the IP-roster dashboard). The endpoint is ALWAYS
# loopback-only — public hits return 404. If this token is set, callers
# also need to send `X-Admin-Token: <value>`. Reach the admin surface
# from a laptop via `aws ssm start-session ... --document-name
# AWS-StartPortForwardingSession --parameters '{"portNumber":["8000"],
# "localPortNumber":["8000"]}'`, then curl http://127.0.0.1:8000/...
WIKI_TUTOR_ADMIN_TOKEN=

# ── MongoDB (local / Docker) ───────────────────────────────
# Used when ENVIRONMENT=local. Connection string is read by utils.mongo_connection.
# The local docker `mongo:6.0` container runs without auth — no user/pass.
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=lasalle_catalog_assistant

# ── MongoDB Atlas (production) ─────────────────────────────
# Used when ENVIRONMENT=dev. Optional for local development.
MONGO_CLUSTER=
CLUSTER_APP_NAME=
MONGO_RW_USERNAME=
MONGO_RW_PASSWORD=
