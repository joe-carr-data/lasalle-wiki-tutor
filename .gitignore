# Python
__pycache__/
*.py[cod]
.venv/

# uv: uv.lock IS committed (pins exact versions for reproducible deploys —
# without it `uv sync --frozen` fails on a fresh clone and the EC2 bootstrap
# halts at step 10).

# Data (too large for git; reproduced by running the script)
data/

# Phase 3 wiki output (regenerable from data/raw_html/)
wiki/

# Pytest cache
.pytest_cache/

# Local secrets (never commit)
.env
.env.local

# macOS
.DS_Store

# IDE
.idea/

# Frontend build (Phase 5)
# node_modules/ is ignored; frontend/dist IS committed so the t3.micro
# demo deploy is `git pull && uv run uvicorn` with no Node toolchain.
frontend/node_modules/

.claude/

# Local cache for fetch_wiki / publish_wiki tarballs
.cache/
